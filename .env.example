# Required for ingest and dashboard (Neon, Vercel Postgres, or any Postgres connection string)
DATABASE_URL="postgres://user:password@host:5432/dbname?sslmode=require"

# Optional: cron-job.org (or similar) calls /api/cron/ingest with this secret
CRON_SECRET="your-secret"

# Optional: Groq API key for AI-generated incident summaries (get one at console.groq.com)
# If unset, incidents are still created but summary will be null.
# GROQ_API_KEY="gsk_..."

# CoinGecko: no key needed for public API (optional override)
# COINGECKO_URL="https://api.coingecko.com/api/v3"

# Optional: CryptoPanic API key for crypto news in the left sidebar (cryptopanic.com)
# CRYPTOPANIC_API_KEY="..."
